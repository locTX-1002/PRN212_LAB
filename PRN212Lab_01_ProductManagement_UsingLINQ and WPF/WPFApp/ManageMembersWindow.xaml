<Window x:Class="WPFApp.ManageMembersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Members" Height="700" Width="1100"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgOverlay}" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1" Padding="20,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="PRN212" Style="{StaticResource Mono}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="/" Foreground="{StaticResource TextTertiary}" Margin="10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="members" Style="{StaticResource Mono}" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Members" Style="{StaticResource H1}" Margin="0,8,0,0"/>
                <TextBlock Text="Create, update, and remove workspace accounts." Style="{StaticResource Subtle}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="dgMembers" Grid.Column="0" SelectionChanged="dgMembers_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="MEMBER ID" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MemberId}" Style="{StaticResource Mono}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="FULL NAME" Binding="{Binding FullName}" Width="*"/>
                    <DataGridTextColumn Header="EMAIL" Binding="{Binding EmailAddress}" Width="*"/>
                    <DataGridTemplateColumn Header="ROLE" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource Badge}" Background="{StaticResource BgSubtle}" BorderBrush="{StaticResource BorderDefault}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="6" Height="6" Fill="{StaticResource AccentFg}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding MemberRole}" Margin="6,0,0,0" FontSize="11" Foreground="{StaticResource TextSecondary}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Inspector -->
            <Border Grid.Column="1" Background="{StaticResource BgOverlay}" BorderBrush="{StaticResource BorderMuted}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="20,14" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="INSPECTOR" Style="{StaticResource HeaderLabel}"/>
                            <TextBlock Text="Account details" Style="{StaticResource H2}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20,18">
                            <TextBlock Text="MEMBER ID" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtMemberID" Margin="0,0,0,14"/>

                            <TextBlock Text="FULL NAME" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtFullName" Margin="0,0,0,14"/>

                            <TextBlock Text="EMAIL" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtEmail" Margin="0,0,0,14"/>

                            <TextBlock Text="ROLE" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cboRole" Margin="0,0,0,14"/>

                            <TextBlock Text="PASSWORD" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <PasswordBox x:Name="txtPassword" Margin="0,0,0,4"/>
                            <TextBlock Text="// leave empty to keep current" Style="{StaticResource MonoSubtle}" Margin="0,0,0,4"/>

                            <Border x:Name="formError" Background="{StaticResource DangerSubtle}" CornerRadius="6"
                                    BorderBrush="{StaticResource DangerFg}" BorderThickness="1"
                                    Padding="10,6" Margin="0,8,0,0" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="!" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource DangerFg}"
                                               FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtFormError" Foreground="{StaticResource DangerFg}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="{StaticResource BgSubtle}" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,1,0,0" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource PrimaryButton}" Margin="0,0,4,4" Click="btnCreate_Click" Content="Create"/>
                            <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource SecondaryButton}" Margin="4,0,0,4" Click="btnUpdate_Click" Content="Update"/>
                            <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource DangerButton}" Margin="0,4,4,0" Click="btnDelete_Click" Content="Delete"/>
                            <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource GhostButton}" Margin="4,4,0,0" Click="btnClear_Click" Content="Clear"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
