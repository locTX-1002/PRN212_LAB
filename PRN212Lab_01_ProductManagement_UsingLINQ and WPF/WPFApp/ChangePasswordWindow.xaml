<Window x:Class="WPFApp.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change password" Width="440" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border CornerRadius="10" Background="{StaticResource BgOverlay}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource BgSubtle}" CornerRadius="10,10,0,0" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1" Padding="20,14">
                <StackPanel>
                    <TextBlock Text="auth · change-password" Style="{StaticResource MonoSubtle}"/>
                    <TextBlock Text="Change password" Style="{StaticResource H1}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,18">
                <TextBlock Text="CURRENT" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="txtOld" Margin="0,0,0,14"/>

                <TextBlock Text="NEW PASSWORD" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="txtNew" Margin="0,0,0,6" PasswordChanged="txtNew_PasswordChanged"/>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border x:Name="sb1" Grid.Column="0" Height="3" Background="{StaticResource BorderMuted}" CornerRadius="1" Margin="0,0,2,0"/>
                    <Border x:Name="sb2" Grid.Column="1" Height="3" Background="{StaticResource BorderMuted}" CornerRadius="1" Margin="2,0,2,0"/>
                    <Border x:Name="sb3" Grid.Column="2" Height="3" Background="{StaticResource BorderMuted}" CornerRadius="1" Margin="2,0,2,0"/>
                    <Border x:Name="sb4" Grid.Column="3" Height="3" Background="{StaticResource BorderMuted}" CornerRadius="1" Margin="2,0,0,0"/>
                </Grid>
                <TextBlock x:Name="strengthLabel" Style="{StaticResource MonoSubtle}" Margin="0,0,0,14"/>

                <TextBlock Text="CONFIRM" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="txtConfirm" Margin="0,0,0,8"/>

                <Border x:Name="msgBox" Background="{StaticResource DangerSubtle}" CornerRadius="6"
                        BorderBrush="{StaticResource DangerFg}" BorderThickness="1"
                        Padding="10,6" Margin="0,8,0,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="!" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource DangerFg}"
                                   FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtMessage" Foreground="{StaticResource DangerFg}" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" Background="{StaticResource BgSubtle}" CornerRadius="0,0,10,10" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,1,0,0" Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0" Content="Cancel" Click="btnCancel_Click"/>
                    <Button Style="{StaticResource PrimaryButton}" Width="100" Content="Save" Click="btnSave_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
