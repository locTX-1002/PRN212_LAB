<Window x:Class="WPFApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Authenticate" Height="540" Width="440"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border CornerRadius="10" Background="{StaticResource BgOverlay}"
            BorderBrush="{StaticResource BorderDefault}" BorderThickness="1" Margin="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Window chrome bar -->
            <Border Grid.Row="0" Background="{StaticResource BgSubtle}" CornerRadius="10,10,0,0"
                    BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1">
                <Grid Height="34">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <Ellipse Width="8" Height="8" Fill="#FF5F57"/>
                        <Ellipse Width="8" Height="8" Fill="#FEBC2E" Margin="6,0,0,0"/>
                        <Ellipse Width="8" Height="8" Fill="#28C840" Margin="6,0,0,0"/>
                        <TextBlock Text="auth · product-management" Style="{StaticResource MonoSubtle}" Margin="16,0,0,0"/>
                    </StackPanel>
                    <Button Width="34" HorizontalAlignment="Right" Background="Transparent" BorderThickness="0"
                            Foreground="{StaticResource TextSecondary}" Cursor="Hand" Click="btnClose_Click" FontSize="12">
                        <TextBlock Text="✕" FontFamily="Segoe UI" />
                    </Button>
                </Grid>
            </Border>

            <!-- Brand -->
            <StackPanel Grid.Row="1" Margin="32,32,32,24">
                <StackPanel Orientation="Horizontal">
                    <!-- Geometric logo mark -->
                    <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource AccentSubtle}"
                            BorderBrush="{StaticResource AccentFg}" BorderThickness="1">
                        <Path Data="M 6 4 L 6 18 L 18 18 M 6 11 L 14 11"
                              Stroke="{StaticResource AccentFg}" StrokeThickness="1.6"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PRN212" Style="{StaticResource Mono}" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <Border Style="{StaticResource Kbd}" Margin="10,0,0,0">
                        <TextBlock Text="v1.0" Style="{StaticResource MonoSubtle}"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="Sign in to continue" Style="{StaticResource H1}" Margin="0,18,0,4"/>
                <TextBlock Text="Use your member credentials to access the workspace." Style="{StaticResource Subtle}"/>
            </StackPanel>

            <!-- Form -->
            <StackPanel Grid.Row="2" Margin="32,0,32,0">
                <Grid Margin="0,0,0,4">
                    <TextBlock Text="MEMBER ID" Style="{StaticResource HeaderLabel}" HorizontalAlignment="Left"/>
                </Grid>
                <TextBox x:Name="txtUser" Margin="0,0,0,14"/>

                <Grid Margin="0,0,0,4">
                    <TextBlock Text="PASSWORD" Style="{StaticResource HeaderLabel}" HorizontalAlignment="Left"/>
                    <TextBlock HorizontalAlignment="Right" FontSize="11">
                        <Hyperlink Foreground="{StaticResource AccentFg}" TextDecorations="None" Click="LinkForgot_Click">Forgot?</Hyperlink>
                    </TextBlock>
                </Grid>
                <PasswordBox x:Name="txtPass" Margin="0,0,0,8"/>

                <Border x:Name="errorBox" Background="{StaticResource DangerSubtle}" CornerRadius="6"
                        BorderBrush="{StaticResource DangerFg}" BorderThickness="1"
                        Padding="10,6" Margin="0,8,0,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="!" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource DangerFg}"
                                   FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtError" Foreground="{StaticResource DangerFg}" FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button x:Name="btnLogin" Style="{StaticResource PrimaryButton}" Margin="0,20,0,0"
                        Click="btnLogin_Click" IsDefault="True" Height="38">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Authenticate" />
                        <Border Style="{StaticResource Kbd}" Background="#0F2A1A" BorderBrush="#1F4D2E" Margin="10,0,0,0">
                            <TextBlock Text="↵" Foreground="#A1E5A8" FontSize="11" FontFamily="Cascadia Mono, Consolas"/>
                        </Border>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Footer -->
            <Border Grid.Row="3" Background="{StaticResource BgSubtle}" CornerRadius="0,0,10,10"
                    BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,1,0,0" Padding="20,10" Margin="0,24,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Style="{StaticResource StatusDot}" Fill="{StaticResource SuccessFg}"/>
                        <TextBlock Text="connected" Style="{StaticResource MonoSubtle}" Margin="6,0,0,0"/>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" Style="{StaticResource MonoSubtle}" Text="localhost:1433"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
