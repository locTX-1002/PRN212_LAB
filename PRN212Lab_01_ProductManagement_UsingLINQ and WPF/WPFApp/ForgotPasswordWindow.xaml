<Window x:Class="WPFApp.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recover" Width="440" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Border CornerRadius="10" Background="{StaticResource BgOverlay}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{StaticResource BgSubtle}" CornerRadius="10,10,0,0" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1" Padding="20,14">
                <StackPanel>
                    <TextBlock Text="auth · recover" Style="{StaticResource MonoSubtle}"/>
                    <TextBlock Text="Recover account" Style="{StaticResource H1}" Margin="0,6,0,0"/>
                    <TextBlock Text="Verify with member ID + registered email" Style="{StaticResource Subtle}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="1" Margin="20,18">
                <TextBlock Text="MEMBER ID" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                <TextBox x:Name="txtMemberId" Margin="0,0,0,12"/>

                <TextBlock Text="EMAIL" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                <TextBox x:Name="txtEmail" Margin="0,0,0,12"/>

                <TextBlock Text="NEW PASSWORD" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="txtNewPassword" Margin="0,0,0,12"/>

                <TextBlock Text="CONFIRM" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                <PasswordBox x:Name="txtConfirmPassword" Margin="0,0,0,8"/>

                <Border x:Name="msgBox" Background="{StaticResource DangerSubtle}" CornerRadius="6"
                        BorderBrush="{StaticResource DangerFg}" BorderThickness="1"
                        Padding="10,6" Margin="0,8,0,0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="!" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource DangerFg}"
                                   FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtMessage" Foreground="{StaticResource DangerFg}" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="2" Background="{StaticResource BgSubtle}" CornerRadius="0,0,10,10" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,1,0,0" Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Width="90" Margin="0,0,8,0" Content="Cancel" Click="btnCancel_Click"/>
                    <Button Style="{StaticResource PrimaryButton}" Width="120" Content="Reset password" Click="btnReset_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
