<Window x:Class="WPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Product Management" Height="740" Width="1200"
        WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>

        <!-- Top bar (compact) -->
        <Border Grid.Row="0" Background="{StaticResource BgOverlay}"
                BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1">
            <Grid Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="22" Height="22" CornerRadius="5" Background="{StaticResource AccentSubtle}"
                            BorderBrush="{StaticResource AccentFg}" BorderThickness="1">
                        <Path Data="M 5 4 L 5 15 L 15 15 M 5 9 L 12 9"
                              Stroke="{StaticResource AccentFg}" StrokeThickness="1.4"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="PRN212" Style="{StaticResource Mono}" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                    <TextBlock Text="/" Foreground="{StaticResource TextTertiary}" Margin="10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="products" Style="{StaticResource Mono}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>

                <!-- Command palette pseudo-trigger -->
                <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                        Background="{StaticResource BgSubtle}" CornerRadius="6"
                        BorderBrush="{StaticResource BorderDefault}" BorderThickness="1" Width="260" Height="26">
                    <Grid Margin="10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontFamily="Segoe UI Emoji" FontSize="11"
                                       Foreground="{StaticResource TextTertiary}" VerticalAlignment="Center"/>
                            <TextBlock Text="Search products..." Style="{StaticResource MonoSubtle}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border Style="{StaticResource Kbd}" HorizontalAlignment="Right">
                            <TextBlock Text="Ctrl K" Style="{StaticResource MonoSubtle}"/>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource BgSubtle}" CornerRadius="12" Padding="8,2"
                            BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Style="{StaticResource StatusDot}" Fill="{StaticResource SuccessFg}" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtCurrentUser" Style="{StaticResource Mono}" Margin="6,0,0,0" FontSize="11"/>
                        </StackPanel>
                    </Border>
                    <Button Style="{StaticResource GhostButton}" Margin="6,0,0,0" Click="btnChangePass_Click" ToolTip="Change password">
                        <TextBlock Text="key" Style="{StaticResource Mono}" FontSize="11"/>
                    </Button>
                    <Button x:Name="btnManageMembers" Style="{StaticResource GhostButton}" Margin="2,0,0,0" Click="btnManageMembers_Click" ToolTip="Members">
                        <TextBlock Text="members" Style="{StaticResource Mono}" FontSize="11"/>
                    </Button>
                    <Border Width="1" Background="{StaticResource BorderMuted}" Margin="8,8"/>
                    <Button Style="{StaticResource GhostButton}" Click="btnLogout_Click" ToolTip="Sign out">
                        <TextBlock Text="logout" Style="{StaticResource Mono}" FontSize="11" Foreground="{StaticResource DangerFg}"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource BgOverlay}"
                    BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,1,0">
                <StackPanel Margin="12,16">
                    <TextBlock Text="WORKSPACE" Style="{StaticResource HeaderLabel}" Margin="6,0,0,8"/>

                    <Border CornerRadius="6" Background="{StaticResource AccentSubtle}" Padding="8,7" Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◆" Foreground="{StaticResource AccentFg}" FontSize="9" VerticalAlignment="Center"/>
                            <TextBlock Text="Products" Foreground="{StaticResource TextPrimary}" FontSize="13" FontWeight="Medium"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <Border Style="{StaticResource Kbd}" HorizontalAlignment="Right" Margin="8,0,0,0">
                                <TextBlock x:Name="sideCount" Style="{StaticResource MonoSubtle}" Text="0"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="6" Padding="8,7" Margin="0,0,0,2" Cursor="Hand"
                            Background="Transparent" MouseLeftButtonUp="Sidebar_Members">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◇" Foreground="{StaticResource TextTertiary}" FontSize="9" VerticalAlignment="Center"/>
                            <TextBlock Text="Members" Foreground="{StaticResource TextSecondary}" FontSize="13"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border CornerRadius="6" Padding="8,7" Margin="0,0,0,2" Background="Transparent">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◇" Foreground="{StaticResource TextTertiary}" FontSize="9" VerticalAlignment="Center"/>
                            <TextBlock Text="Categories" Foreground="{StaticResource TextSecondary}" FontSize="13"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <Rectangle Height="1" Fill="{StaticResource BorderMuted}" Margin="0,12"/>

                    <TextBlock Text="FILTERS" Style="{StaticResource HeaderLabel}" Margin="6,0,0,10"/>

                    <CheckBox x:Name="chkInStockOnly" Content="In stock only" Margin="6,2"
                              Checked="ChkChanged" Unchecked="ChkChanged"/>

                    <TextBlock Text="CATEGORY" Style="{StaticResource HeaderLabel}" Margin="6,16,0,8"/>
                    <ComboBox x:Name="cboFilterCategory" SelectionChanged="cboFilterCategory_SelectionChanged"
                              SelectedValuePath="CategoryID" Margin="0,0,0,4">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="4,2" CornerRadius="3">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Products.Count}" Value="0">
                                                    <Setter Property="Background" Value="#FACC15"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CategoryName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Products.Count}" Value="0">
                                                            <Setter Property="Foreground" Value="#1F2937"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Products.Count, StringFormat=' ({0})'}"
                                                   Margin="4,0,0,0" FontSize="11">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextTertiary}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Products.Count}" Value="0">
                                                            <Setter Property="Foreground" Value="#92400E"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Style="{StaticResource GhostButton}" Click="btnClearFilter_Click" HorizontalAlignment="Left">
                        <TextBlock Text="Clear filters" Style="{StaticResource Mono}" FontSize="11"/>
                    </Button>

                    <Rectangle Height="1" Fill="{StaticResource BorderMuted}" Margin="0,12"/>

                    <TextBlock Text="STATISTICS" Style="{StaticResource HeaderLabel}" Margin="6,0,0,8"/>
                    <Button Style="{StaticResource GhostButton}" Click="btnTopCategory_Click" HorizontalAlignment="Left" Margin="0,2">
                        <TextBlock Text="↑ Top category" Style="{StaticResource Mono}" FontSize="11"/>
                    </Button>
                    <Button Style="{StaticResource GhostButton}" Click="btnTop3Categories_Click" HorizontalAlignment="Left" Margin="0,2">
                        <TextBlock Text="≡ Top 3 categories" Style="{StaticResource Mono}" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Center: Data table -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Border Grid.Row="0" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1" Background="{StaticResource BgCanvas}">
                    <Grid Margin="20,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Products" Style="{StaticResource H1}"/>
                            <TextBlock x:Name="txtSubtitle" Style="{StaticResource Subtle}" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Grid Grid.Column="1" Margin="20,0" MaxWidth="320" HorizontalAlignment="Left">
                            <TextBox x:Name="txtSearch" Padding="32,7,10,7" TextChanged="txtSearch_TextChanged"/>
                            <TextBlock Text="/" Style="{StaticResource Mono}" FontSize="14"
                                       Foreground="{StaticResource TextTertiary}"
                                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="12,0,0,0" IsHitTestVisible="False"/>
                            <TextBlock x:Name="searchPlaceholder" Text="Filter by name..."
                                       Style="{StaticResource MonoSubtle}"
                                       HorizontalAlignment="Left" VerticalAlignment="Center" Margin="32,0,0,0" IsHitTestVisible="False"/>
                        </Grid>
                        <Button Grid.Column="2" Style="{StaticResource SecondaryButton}" Click="btnReload_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="↻" FontFamily="Cascadia Mono, Consolas" Margin="0,0,6,0"/>
                                <TextBlock Text="Reload"/>
                                <Border Style="{StaticResource Kbd}" Margin="8,0,0,0">
                                    <TextBlock Text="R" Style="{StaticResource MonoSubtle}"/>
                                </Border>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Grid -->
                <Grid Grid.Row="1" Background="{StaticResource BgOverlay}">
                    <DataGrid x:Name="dgData" SelectionChanged="dgData_SelectionChanged"
                              ItemsSource="{Binding ProductsView}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="ID" Width="80" SortMemberPath="ProductId">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding ProductId, StringFormat=#{0:00000}}" Style="{StaticResource Mono}"
                                                   Foreground="{StaticResource TextTertiary}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="NAME" Binding="{Binding ProductName}" Width="*"/>
                            <DataGridTemplateColumn Header="CATEGORY" Width="160" SortMemberPath="Category.CategoryName">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Badge}" Background="{StaticResource BgSubtle}"
                                                BorderBrush="{StaticResource BorderDefault}">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentFg}" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Category.CategoryName}" Margin="6,0,0,0" FontSize="11"
                                                           Foreground="{StaticResource TextSecondary}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="PRICE" Width="120" SortMemberPath="UnitPrice">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="₫" Foreground="{StaticResource TextTertiary}" Margin="0,0,3,0"
                                                       FontFamily="Cascadia Mono, Consolas" FontSize="12"/>
                                            <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:N0}}" Style="{StaticResource Mono}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="STOCK" Width="120" SortMemberPath="UnitsInStock">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,2">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource Badge}">
                                                    <Setter Property="Background" Value="#0F2A1A"/>
                                                    <Setter Property="BorderBrush" Value="#1F4D2E"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding UnitsInStock}" Value="0">
                                                            <Setter Property="Background" Value="{StaticResource DangerSubtle}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource DangerEmphasis}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding UnitsInStock}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource Mono}">
                                                        <Setter Property="Foreground" Value="#7EE787"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UnitsInStock}" Value="0">
                                                                <Setter Property="Foreground" Value="{StaticResource DangerFg}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Empty state -->
                    <StackPanel x:Name="emptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <Border Width="48" Height="48" CornerRadius="8" Background="{StaticResource BgSubtle}"
                                BorderBrush="{StaticResource BorderDefault}" BorderThickness="1" HorizontalAlignment="Center">
                            <Path Data="M 8 8 L 24 24 M 24 8 L 8 24" Stroke="{StaticResource TextTertiary}"
                                  StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No products match" FontSize="13" FontWeight="Medium" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                        <TextBlock Text="Adjust your filters or create a new product." Style="{StaticResource Subtle}" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Loading -->
                    <Border x:Name="loadingOverlay" Background="#CC0D1117" Visibility="Collapsed">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <ProgressBar IsIndeterminate="True" Width="180" Height="2" Foreground="{StaticResource AccentFg}"
                                         BorderThickness="0" Background="{StaticResource BgSubtle}"/>
                            <TextBlock Text="loading..." Style="{StaticResource MonoSubtle}" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Right inspector panel -->
            <Border Grid.Column="2" Background="{StaticResource BgOverlay}"
                    BorderBrush="{StaticResource BorderMuted}" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="20,14" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="INSPECTOR" Style="{StaticResource HeaderLabel}"/>
                            <TextBlock x:Name="inspectorTitle" Text="No selection" Style="{StaticResource H2}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="20,18">
                            <TextBlock Text="ID" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtProductID" IsEnabled="False" Margin="0,0,0,14"/>

                            <TextBlock Text="NAME" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtProductName" Margin="0,0,0,14"/>

                            <TextBlock Text="PRICE" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtPrice" Margin="0,0,0,14"/>

                            <TextBlock Text="STOCK" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtUnitsInStock" Margin="0,0,0,14"/>

                            <TextBlock Text="CATEGORY" Style="{StaticResource HeaderLabel}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cboCategory" Margin="0,0,0,8"
                                      DisplayMemberPath="CategoryName" SelectedValuePath="CategoryID"/>

                            <Border x:Name="formError" Background="{StaticResource DangerSubtle}" CornerRadius="6"
                                    BorderBrush="{StaticResource DangerFg}" BorderThickness="1"
                                    Padding="10,6" Margin="0,8,0,0" Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="!" FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource DangerFg}"
                                               FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtFormError" Foreground="{StaticResource DangerFg}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="{StaticResource BgSubtle}" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,1,0,0" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Grid.Column="0" Style="{StaticResource PrimaryButton}" Margin="0,0,4,4" Click="btnCreate_Click" Content="Create"/>
                            <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource SecondaryButton}" Margin="4,0,0,4" Click="btnUpdate_Click" Content="Update"/>
                            <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource DangerButton}" Margin="0,4,4,0" Click="btnDelete_Click" Content="Delete"/>
                            <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource GhostButton}" Margin="4,4,0,0" Click="btnClear_Click" Content="Clear"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="{StaticResource BgOverlay}" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,1,0,0">
            <Grid Margin="14,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Style="{StaticResource StatusDot}" Fill="{StaticResource SuccessFg}"/>
                    <TextBlock Text="ready" Style="{StaticResource MonoSubtle}" Margin="6,0,0,0"/>
                    <TextBlock Text="·" Margin="10,0" Style="{StaticResource MonoSubtle}"/>
                    <TextBlock x:Name="statusCount" Style="{StaticResource MonoSubtle}"/>
                    <TextBlock Text="·" Margin="10,0" Style="{StaticResource MonoSubtle}"/>
                    <TextBlock x:Name="statusFilter" Style="{StaticResource MonoSubtle}"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="db: localhost:1433" Style="{StaticResource MonoSubtle}"/>
                    <TextBlock Text="·" Margin="10,0" Style="{StaticResource MonoSubtle}"/>
                    <TextBlock Text="UTF-8" Style="{StaticResource MonoSubtle}"/>
                    <TextBlock Text="·" Margin="10,0" Style="{StaticResource MonoSubtle}"/>
                    <TextBlock x:Name="statusTime" Style="{StaticResource MonoSubtle}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
