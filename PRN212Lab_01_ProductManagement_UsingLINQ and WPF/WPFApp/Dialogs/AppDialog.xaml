<Window x:Class="WPFApp.Dialogs.AppDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Border CornerRadius="10" Background="{StaticResource BgOverlay}" BorderBrush="{StaticResource BorderDefault}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource BgSubtle}" CornerRadius="10,10,0,0" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,0,0,1" Padding="20,14">
                <StackPanel Orientation="Horizontal">
                    <Border x:Name="iconBg" Width="28" Height="28" CornerRadius="6" BorderThickness="1">
                        <TextBlock x:Name="icon" Foreground="White" FontFamily="Cascadia Mono, Consolas" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="titleText" Style="{StaticResource H2}"/>
                        <TextBlock x:Name="kindLabel" Style="{StaticResource MonoSubtle}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Grid.Row="1" x:Name="messageText" Margin="20,16,20,8"
                       TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextPrimary}"/>

            <Border Grid.Row="2" Background="{StaticResource BgSubtle}" CornerRadius="0,0,10,10" BorderBrush="{StaticResource BorderMuted}" BorderThickness="0,1,0,0" Padding="20,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnCancel" Content="Cancel" Style="{StaticResource SecondaryButton}"
                            Width="90" Margin="0,0,8,0" Click="btnCancel_Click" Visibility="Collapsed"/>
                    <Button x:Name="btnOk" Content="OK" Style="{StaticResource PrimaryButton}"
                            Width="90" Click="btnOk_Click" IsDefault="True"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
